;
;Module Name:
;
;    USBCANalyst_ii_plus.INF
;
;Abstract:
;    Installation inf for the USBCANalyst-II+ Board
;
;--*/

[Version]
Signature = "$WINDOWS NT$"
Class = %DeviceClassName%
ClassGUID = {0BD2B8A1-FFB7-413d-BEDF-47FBDDAEACB1}
Provider = %Provider%
DriverVer=04/24/2015,2.0.0.8
CatalogFile=usbcanalyst_ii_plus.cat

; ================= Class section =====================

[ClassInstall32]
Addreg=USBCANALYST_ClassReg     

[USBCANALYST_ClassReg]
HKR,,,0,%DeviceClassName%
HKR,,Icon,,-5

; ================= Device section =====================

[Manufacturer]
%MfgName%=USBCANALYST_Mfg,NTx86,NTAMD64

; For Win2K
[USBCANALYST_Mfg]
%DeviceDesc%=USBCANALYST_Inst.NT, %DEVICE_ID% 

; For XP and later
[USBCANALYST_Mfg.NTx86]
%DeviceDesc%=USBCANALYST_Inst.NT, %DEVICE_ID% 

; For AMD64
[USBCANALYST_Mfg.NTAMD64]
%DeviceDesc%=USBCANALYST_Inst.NTAMD64, %DEVICE_ID% 

[USBCANALYST_Inst.NT]
CopyFiles=USBCANALYST_Drv

[USBCANALYST_Inst.NTAMD64]
CopyFiles=USBCANALYST_Drv


[USBCANALYST_Drv]
%DEVICE_DRIVER%,,,2

;============ Source & Destination ==========

[SourceDisksNames]
1=%Disk_Description%,,,

[SourceDisksFiles]
%DEVICE_DRIVER%  = 1,,

[DestinationDirs]
USBCANALYST_Drv  = 12 


;=============== Service ==================
[USBCANALYST_Inst.NT.Services]
Addservice = USBCANALYST, 0x00000002, USBCANALYST_Svc

[USBCANALYST_Inst.NTAMD64.Services]
Addservice = USBCANALYST, 0x00000002, USBCANALYST_Svc

[USBCANALYST_Svc]
DisplayName    = %SvcDesc%
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\%DEVICE_DRIVER%
LoadOrderGroup = Base





;-------------- WDF Coinstaller installation
[DestinationDirs]
CoInstaller_CopyFiles = 11

[SourceDisksFiles]
WdfCoInstaller01009.dll=1 ; make sure the number matches with SourceDisksNames

[USBCANALYST_Inst.NT.CoInstallers]
AddReg=CoInstaller_AddReg
CopyFiles=CoInstaller_CopyFiles

[USBCANALYST_Inst.NTAMD64.CoInstallers]
AddReg=CoInstaller_AddReg
CopyFiles=CoInstaller_CopyFiles

[CoInstaller_CopyFiles]
wdfcoinstaller01009.dll


[CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "wdfcoinstaller01009.dll,WdfCoInstaller"

[USBCANALYST_Inst.NT.Wdf]
KmdfService = USBCANALYST, USBCANALYST_wdfsect

[USBCANALYST_Inst.NTAMD64.Wdf]
KmdfService = USBCANALYST, USBCANALYST_wdfsect

[USBCANALYST_wdfsect]
KmdfLibraryVersion = 1.9

;---------------------- Strings -----------------------------;

[Strings]
DeviceClassName = "ZlGCAN"
Provider		= "ZLGMCU DEVELOPMENT Co,LTD"
MfgName			= "GUANGZHOU ZHIYUAN ELECTRONICS Co.Ltd"
Disk_Description= "USBCANALYST Installation Disk"
SvcDesc			= "USBCANALYST.ServiceDesc"
DEVICE_ID       = "USB\VID_0471&PID_1261"
DeviceDesc		= "USBCANALYST_II_PLUS"
;DEVICE_TYPE         = 600
;DEVICE_NAME         = "USBCANALYST" 
DEVICE_DRIVER       = "USBCANALYST_II_PLUS.sys"
